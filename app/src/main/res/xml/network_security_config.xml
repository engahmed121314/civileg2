<network-security-config>
    <!-- Block all cleartext (HTTP) traffic -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Only system-trusted CAs -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Debug builds only: allow cleartext for localhost testing -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>