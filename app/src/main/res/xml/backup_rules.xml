<?xml version="1.0" encoding="utf-8"?>
<!-- Civil Engineer Pro - Restrictive backup rules for security -->
<!-- Developer: Eng. Ahmed Magdy -->
<full-backup-content>
    <!-- Exclude all sensitive data from backup -->
    <exclude domain="sharedpref" path="."/>
    <exclude domain="database" path="."/>
    <exclude domain="file" path="."/>
    <!-- Only allow project exports to be backed up -->
    <include domain="external" path="CivilEngineerPro/exports/"/>
</full-backup-content>